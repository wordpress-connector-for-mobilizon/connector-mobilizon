{
  "name": "connector-mobilizon",
  "version": "2.3.0-next",
  "description": "Display Mobilizon events in WordPress.",
  "private": true,
  "scripts": {
    "build-dev": "webpack --mode=development && gulp inject",
    "build-prod": "rimraf -- build && ava && webpack --mode=production && gulp inject",
    "clean": "rimraf -- build",
    "coverage": "c8 --all --reporter=html --reporter=text --include=source/**/*.js ava",
    "eslint": "npx eslint './source/**/*.js'",
    "format": "npx prettier --write .",
    "prepare": "husky",
    "test": "ava && ./vendor/bin/phpunit"
  },
  "author": {
    "name": "Daniel Waxweiler",
    "url": "https://www.danielwaxweiler.net/"
  },
  "funding": {
    "type": "individual",
    "url": "https://paypal.me/dwaxweiler"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "graphql": "16.14.0",
    "luxon": "3.7.2"
  },
  "devDependencies": {
    "@babel/core": "8.0.0-rc.6",
    "@babel/eslint-parser": "8.0.0-rc.6",
    "@babel/preset-env": "8.0.0-rc.6",
    "@babel/preset-react": "8.0.0-rc.6",
    "@wordpress/eslint-plugin": "25.3.0",
    "ava": "8.0.1",
    "babel-loader": "10.1.1",
    "c8": "11.0.0",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-ava": "17.0.0",
    "esm": "3.2.25",
    "gulp": "5.0.1",
    "gulp-replace": "1.1.4",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  },
  "ava": {
    "files": [
      "./source/**/*test.js"
    ]
  },
  "additionalDetails": {
    "niceName": "Connector for Mobilizon",
    "phpMinimumVersion": 7.4,
    "wordpressMinimumVersion": 5.6,
    "wordpressTestedUpToVersion": "7.0"
  },
  "lint-staged": {
    "source/**/*.js": "eslint",
    "**/*": "prettier --write --ignore-unknown"
  },
  "overrides": {
    "@babel/core": "8.0.0-rc.6",
    "@wordpress/babel-preset-default": {
      "@babel/core": "8.0.0-rc.6",
      "@babel/preset-env": "$@babel/preset-env",
      "@babel/preset-typescript": "8.0.0-rc.6",
      "@babel/plugin-syntax-import-attributes": "8.0.0-rc.1"
    }
  }
}
